# TMDB v3 API key — read access for movie/TV data and (with a user session)
# the signed-in user's favorites + watchlist. Safe to expose in the client.
VITE_APP_API_KEY=

# OMDb API key — used for the IMDb rating in the details view.
VITE_APP_OMDB_API_KEY=

# Google OAuth Client ID (Web application). Create one at
# https://console.cloud.google.com/apis/credentials and add your app origins
# (e.g. http://localhost:5173 and your production URL) to "Authorized
# JavaScript origins". The client ID is public and safe to ship in the bundle.
VITE_GOOGLE_CLIENT_ID=
