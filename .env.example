# TMDB v4 API Read Access Token (Bearer). Get it from TMDB → Settings → API →
# "API Read Access Token" — a long JWT, NOT the old v3 api_key. Catalog reads
# only; safe to ship in the client bundle.
VITE_TMDB_READ_TOKEN=

# OMDb API key — used for the IMDb rating in the details view.
VITE_APP_OMDB_API_KEY=

# Supabase project (Project Settings → API). Backs Google sign-in and the
# user's favorites + watch-later. The anon key is public — Row-Level Security
# is what protects the data.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Build-time ONLY — used by drizzle-kit for migrations (npm run db:migrate).
# NEVER prefix this with VITE_ (Vite would inline it into the client bundle and
# leak the DB password). Use the Supabase direct / session pooler connection
# string on port 5432 (NOT the 6543 transaction pooler). Provide it via the
# shell or a CI secret, not a committed file:
#   DATABASE_URL=postgresql://postgres:[password]@db.[ref].supabase.co:5432/postgres
